# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ── Auth ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=your-secret-at-least-32-characters-long-change-this

# ── App ───────────────────────────────────────────────────
# Local dev:   http://localhost:3000
# Production:  https://ticket.rimacle.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WhatsApp worker
# Vercel/serverless must use Meta WhatsApp Cloud API. Local can still use WhatsApp Web.
WHATSAPP_ENABLED=true
WHATSAPP_PROVIDER=cloud_api
WHATSAPP_CLOUD_API_VERSION=v21.0
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_ACCESS_TOKEN=
# Optional, but recommended for campaigns outside the 24-hour support window.
WHATSAPP_CLOUD_TEMPLATE_NAME=
WHATSAPP_CLOUD_TEMPLATE_LANGUAGE=en_US
WHATSAPP_CLOUD_TEMPLATE_PARAM_ORDER=event,date,venue,link
